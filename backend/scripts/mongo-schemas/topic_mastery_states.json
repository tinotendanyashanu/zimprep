{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["mastery_id", "user_id", "subject", "topic_id", "mastery_level", "computed_at", "version", "trace_id"],
    "properties": {
      "mastery_id": {
        "bsonType": "string",
        "description": "Unique mastery state identifier"
      },
      "user_id": {
        "bsonType": "string",
        "description": "Student identifier"
      },
      "subject": {
        "bsonType": "string",
        "description": "Subject code"
      },
      "topic_id": {
        "bsonType": "string",
        "description": "Topic identifier"
      },
      "mastery_level": {
        "enum": ["NOT_INTRODUCED", "EMERGING", "DEVELOPING", "PROFICIENT", "MASTERED"],
        "description": "Mastery classification level"
      },
      "justification": {
        "bsonType": "object",
        "description": "Full trace of how mastery was determined",
        "properties": {
          "attempts_used": {
            "bsonType": "array",
            "description": "List of attempt IDs used in classification",
            "items": {
              "bsonType": "string"
            }
          },
          "score_summary": {
            "bsonType": "object",
            "description": "Aggregated performance metrics",
            "properties": {
              "average_score": {"bsonType": "double"},
              "latest_score": {"bsonType": "double"},
              "best_score": {"bsonType": "double"}
            }
          },
          "trend_direction": {
            "enum": ["improving", "stable", "declining"],
            "description": "Performance trend over time"
          },
          "confidence_weight": {
            "bsonType": "double",
            "description": "Reliability score for this classification (0.0-1.0)"
          },
          "classification_method": {
            "enum": ["ai_assisted", "rule_based", "insufficient_data"],
            "description": "Method used for classification"
          }
        }
      },
      "computed_at": {
        "bsonType": "date",
        "description": "Timestamp when mastery was computed"
      },
      "version": {
        "bsonType": "string",
        "description": "Mastery modeling algorithm version"
      },
      "trace_id": {
        "bsonType": "string",
        "description": "Request trace ID for audit trail"
      },
      "_immutable": {
        "bsonType": "bool",
        "description": "Immutability flag (always true)"
      },
      "_created_at": {
        "bsonType": "date",
        "description": "MongoDB insertion timestamp"
      }
    }
  }
}
