{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["snapshot_id", "user_id", "subject", "computed_at", "version", "trace_id"],
    "properties": {
      "snapshot_id": {
        "bsonType": "string",
        "description": "Unique snapshot identifier"
      },
      "user_id": {
        "bsonType": "string",
        "description": "Student identifier"
      },
      "subject": {
        "bsonType": "string",
        "description": "Subject code (e.g., MATHEMATICS_4024)"
      },
      "topic_id": {
        "bsonType": "string",
        "description": "Optional topic identifier for filtered analysis"
      },
      "computed_at": {
        "bsonType": "date",
        "description": "Timestamp when analytics were computed"
      },
      "source_attempt_ids": {
        "bsonType": "array",
        "description": "List of exam attempt IDs used in this analysis",
        "items": {
          "bsonType": "string"
        }
      },
      "metrics": {
        "bsonType": "object",
        "description": "Statistical metrics computed from attempts",
        "properties": {
          "rolling_average": {
            "bsonType": "double",
            "description": "Rolling average performance score"
          },
          "trend_slope": {
            "bsonType": "double",
            "description": "Trend direction (positive = improving, negative = declining)"
          },
          "volatility": {
            "bsonType": "double",
            "description": "Standard deviation of performance (consistency measure)"
          },
          "confidence_score": {
            "bsonType": "double",
            "description": "Confidence-weighted performance metric"
          },
          "attempt_count": {
            "bsonType": "int",
            "description": "Number of attempts analyzed"
          }
        }
      },
      "version": {
        "bsonType": "string",
        "description": "Analytics algorithm version for reproducibility"
      },
      "trace_id": {
        "bsonType": "string",
        "description": "Request trace ID for audit trail"
      },
      "_immutable": {
        "bsonType": "bool",
        "description": "Immutability flag (always true)"
      },
      "_created_at": {
        "bsonType": "date",
        "description": "MongoDB insertion timestamp"
      }
    }
  }
}
