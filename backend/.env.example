# ===== AI =====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===== GOOGLE CLOUD VISION (for handwriting OCR) =====
# Paste the full JSON string of your service account key (one line), OR set a file path
GOOGLE_APPLICATION_CREDENTIALS=

# ===== DATABASE =====
MONGO_URI=mongodb://localhost:27017
MONGO_DB=zimprep

# ===== SUPABASE =====
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== AUTH =====
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ===== BILLING (Flutterwave) =====
# Get these from https://dashboard.flutterwave.com/dashboard/settings/apis
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-...
# Set this to any random string, then copy the same value into
# Flutterwave dashboard → Webhooks → "Secret Hash"
BILLING_WEBHOOK_SECRET=

# ===== APP =====
ENV=production
LOG_LEVEL=INFO
# Comma-separated list of allowed frontend origins
# e.g. https://zimprep.vercel.app,http://localhost:3000
CORS_ORIGINS=https://your-frontend.vercel.app
