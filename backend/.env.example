# ===== ENVIRONMENT CONFIGURATION =====
# Environment type: local, development, staging, production, audit
ENV=development

# AUDIT MODE (PHASE B5)
# When true, all write operations are blocked (forensic/compliance mode)
AUDIT_MODE=false

# ===== DATABASE CONFIGURATION =====
# PostgreSQL connection string for relational data
# Production example: postgresql+asyncpg://user:password@host:5432/zimprep
DATABASE_URL=sqlite+aiosqlite:///:memory:

# MongoDB connection string for document storage (exams, submissions, audits)
# Production example: mongodb://user:password@host:27017/zimprep?authSource=admin
MONGODB_URI=mongodb://localhost:27017

# Redis for caching, rate limiting, and background job queues
# Production example: redis://user:password@host:6379/0
REDIS_URL=redis://localhost:6379/0

# ===== AI CONFIGURATION (REQUIRED IN PRODUCTION) =====
# OpenAI API key for AI engines (embedding, retrieval, reasoning, recommendation)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ===== AUTHENTICATION (REQUIRED) =====
# JWT secret for token signing
# CRITICAL: Must be 32+ characters in production/staging
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE-THIS-IN-PRODUCTION-USE-LONG-RANDOM-STRING-MIN-32-CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ===== BILLING INTEGRATION (REQUIRED IN PRODUCTION) =====
# Webhook secret from your billing provider (e.g., Stripe)
# Used to verify webhook signatures
BILLING_WEBHOOK_SECRET=

# ===== IDENTITY & SUBSCRIPTION ENGINE =====
# Cache TTL for identity resolution (seconds)
IDENTITY_CACHE_TTL_SECONDS=300

# Rate limit window (seconds)
RATE_LIMIT_WINDOW_SECONDS=86400

# ===== OBSERVABILITY (PHASE B5) =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (production) or text (development)
LOG_FORMAT=json
