# Root gitignore for monorepo

# Dependencies
node_modules/
__pycache__/
*.py[cod]
*$py.class

# Build outputs
.next/
out/
dist/
build/
*.egg-info/

# Environment files
.env
.env*.local
!.env.example

# Python virtual environments
venv/
env/
ENV/
.venv

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
coverage/
.coverage

# Misc
*.pem
